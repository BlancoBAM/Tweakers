// Tweakers - Main Application Window
import { Theme, TweakButton, Card, ToggleSwitch, TweakSlider, TweakSelect, ProgressBar } from "theme.slint";

// Named struct for COSMIC theme data — generates a proper Rust type
struct CosmicThemeData {
    id: int,
    name: string,
    author: string,
    is-dark: bool,
    accent-r: int,
    accent-g: int,
    accent-b: int,
    bg-r: int,
    bg-g: int,
    bg-b: int,
    downloads: int,
}

// Czkawka scan mode button — styled to match krokiet's sidebar item look
component CzkawkaModeButton inherits Rectangle {
    in property <string> icon: "📄";
    in property <string> label: "";
    in property <string> description: "";
    in property <bool> available: false;
    in property <bool> scanning: false;
    callback clicked;

    height: 72px;
    background: available ? Theme.surface-variant : #151515;
    border-radius: Theme.radius-md;
    border-width: 1px;
    border-color: touch.has-hover && available ? Theme.accent : Theme.border;
    opacity: available ? 1.0 : 0.45;

    animate border-color { duration: 120ms; }
    animate background { duration: 120ms; }

    states [
        hovered when touch.has-hover && available && !scanning: {
            background: #2d2d20;
        }
    ]

    touch := TouchArea {
        mouse-cursor: (available && !scanning) ? pointer : default;
        clicked => {
            if (available && !scanning) {
                root.clicked();
            }
        }
    }

    HorizontalLayout {
        padding: Theme.spacing-sm;
        spacing: Theme.spacing-sm;

        Text {
            text: icon;
            font-size: 28px;
            vertical-alignment: center;
            width: 40px;
        }

        VerticalLayout {
            spacing: 2px;
            alignment: center;

            Text {
                text: label;
                color: available ? Theme.text-primary : Theme.text-muted;
                font-size: Theme.font-sm;
                font-weight: 600;
            }
            Text {
                text: description;
                color: Theme.text-muted;
                font-size: Theme.font-xs;
            }
        }

        Rectangle { horizontal-stretch: 1; }

        if available : Text {
            text: scanning ? "⏳" : "›";
            color: Theme.accent;
            font-size: Theme.font-lg;
            font-weight: 700;
            vertical-alignment: center;
        }
    }
}

// Sidebar navigation item
component NavItem inherits Rectangle {
    in property <string> label: "";
    in property <string> icon: "";
    in property <bool> active: false;
    callback clicked;
    
    height: 48px;
    background: active ? Theme.surface-variant : transparent;
    border-radius: Theme.radius-md;
    
    states [
        hovered when touch.has-hover && !active: {
            background: Theme.surface;
        }
    ]
    
    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
    
    HorizontalLayout {
        padding-left: Theme.spacing-md;
        padding-right: Theme.spacing-md;
        spacing: Theme.spacing-sm;
        
        Rectangle {
            width: 4px;
            background: active ? Theme.accent : transparent;
            border-radius: 2px;
        }
        
        Text {
            text: icon;
            font-size: Theme.font-lg;
            color: active ? Theme.accent : Theme.text-secondary;
            vertical-alignment: center;
        }
        
        Text {
            text: label;
            font-size: Theme.font-md;
            color: active ? Theme.text-primary : Theme.text-secondary;
            font-weight: active ? 600 : 400;
            vertical-alignment: center;
        }
    }
}

// Sudo password dialog — uses a real TextInput for password entry
component SudoDialog inherits Rectangle {
    in property <bool> dialog-visible: false;
    in property <string> action-description: "";
    in-out property <string> password: "";
    in property <bool> is-loading: false;
    in property <string> error-message: "";
    callback submit(string);
    callback cancel;
    
    background: #00000099;
    
    if dialog-visible : Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 420px;
        height: 300px;
        background: Theme.surface;
        border-radius: Theme.radius-lg;
        border-width: 1px;
        border-color: Theme.border;
        drop-shadow-color: #000000aa;
        drop-shadow-blur: 24px;
        drop-shadow-offset-y: 8px;
        
        VerticalLayout {
            padding: Theme.spacing-lg;
            spacing: Theme.spacing-md;
            
            // Header
            HorizontalLayout {
                spacing: Theme.spacing-sm;
                Text {
                    text: "🔐";
                    font-size: Theme.font-xl;
                    vertical-alignment: center;
                }
                Text {
                    text: "Authentication Required";
                    font-size: Theme.font-lg;
                    font-weight: 600;
                    color: Theme.text-primary;
                    vertical-alignment: center;
                }
            }
            
            // Description
            Text {
                text: action-description != "" ? action-description : "Enter your password to apply system changes";
                color: Theme.text-secondary;
                font-size: Theme.font-sm;
                wrap: word-wrap;
            }
            
            // Real password input field
            pwd-box := Rectangle {
                height: 44px;
                background: Theme.surface-variant;
                border-radius: Theme.radius-md;
                border-width: 1px;
                border-color: error-message != "" ? Theme.error : (pwd-input.has-focus ? Theme.accent : Theme.border);
                clip: true;

                animate border-color { duration: 100ms; }

                // Placeholder text (shown when empty)
                if password == "" : Text {
                    x: Theme.spacing-md;
                    y: (parent.height - self.preferred-height) / 2;
                    text: "Enter password…";
                    color: Theme.text-muted;
                    font-size: Theme.font-md;
                }

                // The actual text input
                pwd-input := TextInput {
                    x: Theme.spacing-md;
                    y: (parent.height - self.preferred-height) / 2;
                    width: parent.width - Theme.spacing-md * 2;
                    input-type: InputType.password;
                    text <=> password;
                    font-size: Theme.font-md;
                    color: Theme.text-primary;
                    enabled: !is-loading;
                    // Submit on Enter key
                    accepted => { submit(password); }
                }
            }
            
            // Error message
            if error-message != "" : Text {
                text: "⚠ " + error-message;
                color: Theme.error;
                font-size: Theme.font-sm;
            }
            
            // Loading indicator
            if is-loading : ProgressBar {
                progress: 0.5;
                label: "Applying changes…";
            }
            
            // Buttons
            HorizontalLayout {
                spacing: Theme.spacing-md;
                alignment: end;
                
                TweakButton {
                    label: "Cancel";
                    enabled: !is-loading;
                    clicked => { cancel(); }
                }
                
                TweakButton {
                    label: "Authenticate";
                    primary: true;
                    enabled: !is-loading && password != "";
                    clicked => { submit(password); }
                }
            }
        }
    }
}

// Live resource usage bar — CPU% and RAM% with animated thin bars
component ResourceBar inherits Rectangle {
    in property <float> cpu-pct: 0;
    in property <float> ram-pct: 0;
    in property <int> ram-used-mb: 0;
    in property <int> ram-total-mb: 0;

    height: 56px;
    background: Theme.surface;
    border-radius: Theme.radius-md;
    border-width: 1px;
    border-color: Theme.border;

    HorizontalLayout {
        padding-left: Theme.spacing-md;
        padding-right: Theme.spacing-md;
        padding-top: Theme.spacing-sm;
        padding-bottom: Theme.spacing-sm;
        spacing: Theme.spacing-lg;

        // CPU block
        VerticalLayout {
            spacing: 3px;
            horizontal-stretch: 1;
            alignment: center;

            HorizontalLayout {
                Text {
                    text: "CPU";
                    color: Theme.text-secondary;
                    font-size: Theme.font-xs;
                    font-weight: 600;
                    horizontal-stretch: 1;
                }
                Text {
                    text: round(cpu-pct) + "%";
                    color: cpu-pct > 80 ? Theme.error : (cpu-pct > 50 ? Theme.warning : Theme.accent);
                    font-size: Theme.font-xs;
                    font-weight: 700;
                }
            }

            Rectangle {
                height: 6px;
                background: Theme.surface-variant;
                border-radius: 3px;

                Rectangle {
                    width: parent.width * (cpu-pct / 100);
                    height: parent.height;
                    background: cpu-pct > 80 ? Theme.error : (cpu-pct > 50 ? Theme.warning : Theme.accent);
                    border-radius: 3px;
                    animate width { duration: 600ms; easing: ease-out; }
                }
            }
        }

        // Divider
        Rectangle {
            width: 1px;
            background: Theme.border;
        }

        // RAM block
        VerticalLayout {
            spacing: 3px;
            horizontal-stretch: 1;
            alignment: center;

            HorizontalLayout {
                Text {
                    text: "RAM";
                    color: Theme.text-secondary;
                    font-size: Theme.font-xs;
                    font-weight: 600;
                    horizontal-stretch: 1;
                }
                Text {
                    text: ram-total-mb > 0
                        ? round(ram-used-mb / 1024 * 10) / 10 + " / " + round(ram-total-mb / 1024 * 10) / 10 + " GB"
                        : round(ram-pct) + "%";
                    color: ram-pct > 90 ? Theme.error : (ram-pct > 70 ? Theme.warning : Theme.accent);
                    font-size: Theme.font-xs;
                    font-weight: 700;
                }
            }

            Rectangle {
                height: 6px;
                background: Theme.surface-variant;
                border-radius: 3px;

                Rectangle {
                    width: parent.width * (ram-pct / 100);
                    height: parent.height;
                    background: ram-pct > 90 ? Theme.error : (ram-pct > 70 ? Theme.warning : Theme.success);
                    border-radius: 3px;
                    animate width { duration: 600ms; easing: ease-out; }
                }
            }
        }
    }
}

// Toast notification — slides in from the bottom-right, auto-dismissed from Rust
component ToastNotification inherits Rectangle {
    in property <bool> toast-visible: false;
    in property <string> message: "";
    in property <bool> is-success: true;

    width: 340px;
    height: message != "" ? 54px : 0px;
    opacity: toast-visible ? 1.0 : 0.0;
    background: is-success ? #1a3525 : #3a1a1a;
    border-radius: Theme.radius-md;
    border-width: 1px;
    border-color: is-success ? Theme.success : Theme.error;
    drop-shadow-color: #000000cc;
    drop-shadow-blur: 16px;
    drop-shadow-offset-y: 4px;

    animate opacity { duration: 280ms; easing: ease-in-out; }
    animate height { duration: 200ms; easing: ease-out; }

    HorizontalLayout {
        padding-left: Theme.spacing-md;
        padding-right: Theme.spacing-md;
        spacing: Theme.spacing-sm;
        alignment: center;

        Text {
            text: is-success ? "✓" : "✗";
            color: is-success ? Theme.success : Theme.error;
            font-size: Theme.font-lg;
            font-weight: 700;
            vertical-alignment: center;
        }
        Text {
            text: message;
            color: Theme.text-primary;
            font-size: Theme.font-sm;
            vertical-alignment: center;
            horizontal-stretch: 1;
            wrap: word-wrap;
        }
    }
}

// Individual COSMIC theme card for the gallery
component CosmicThemeCard inherits Rectangle {
    in property <string> theme-name: "";
    in property <string> theme-author: "";
    in property <int> theme-downloads: 0;
    in property <bool> theme-is-dark: true;
    in property <color> accent-col: #7aa2f7;
    in property <color> bg-col: #1a1b26;
    in property <bool> installing: false;
    callback install-clicked;

    height: 88px;
    background: card-touch.has-hover ? Theme.surface : Theme.surface-variant;
    border-radius: Theme.radius-md;
    border-width: 1px;
    border-color: card-touch.has-hover ? accent-col : Theme.border;
    animate border-color { duration: 120ms; }
    animate background { duration: 120ms; }

    card-touch := TouchArea { mouse-cursor: default; }

    HorizontalLayout {
        padding: Theme.spacing-sm;
        spacing: Theme.spacing-sm;

        // Colour preview swatch
        Rectangle {
            width: 48px;
            border-radius: Theme.radius-sm;
            background: bg-col;
            border-width: 1px;
            border-color: Theme.border;

            Rectangle {
                x: parent.width - self.width - 4px;
                y: parent.height - self.height - 4px;
                width: 16px;
                height: 16px;
                border-radius: 8px;
                background: accent-col;
            }
        }

        // Info
        VerticalLayout {
            spacing: 2px;
            alignment: center;
            horizontal-stretch: 1;

            Text {
                text: theme-name;
                color: Theme.text-primary;
                font-size: Theme.font-sm;
                font-weight: 600;
                overflow: elide;
            }
            Text {
                text: "by " + theme-author;
                color: Theme.text-secondary;
                font-size: Theme.font-xs;
            }
            HorizontalLayout {
                spacing: Theme.spacing-sm;
                Text {
                    text: theme-is-dark ? "🌙 Dark" : "☀ Light";
                    color: Theme.text-muted;
                    font-size: Theme.font-xs;
                }
                Text {
                    text: "↓ " + theme-downloads;
                    color: Theme.text-muted;
                    font-size: Theme.font-xs;
                }
            }
        }

        // Install button
        TweakButton {
            label: installing ? "Installing…" : "Install";
            primary: !installing;
            enabled: !installing;
            clicked => { install-clicked(); }
        }
    }
}

// Tweaks Tab Content
component TweaksTab inherits Rectangle {
    in-out property <int> cpu-governor-index: 1;
    in-out property <bool> turbo-enabled: true;
    in-out property <float> swappiness: 10;
    in-out property <float> vfs-cache-pressure: 50;
    in-out property <bool> zram-enabled: true;
    in-out property <int> io-scheduler-index: 0;
    in-out property <bool> trim-enabled: true;
    in-out property <bool> intel-guc-enabled: false;
    in-out property <bool> intel-psr-enabled: false;
    in-out property <bool> intel-fbc-enabled: false;
    in-out property <bool> wifi-powersave: false;
    in-out property <bool> audio-powersave: false;
    
    // Network
    in-out property <float> tcp-fastopen: 3;
    in-out property <bool> tcp-low-latency: false;
    in-out property <bool> bbr-enabled: false;
    
    // Kernel
    in-out property <bool> watchdog-enabled: true;
    in-out property <int> thp-index: 1;

    // Resource monitor
    in property <float> cpu-usage: 0;
    in property <float> ram-usage-pct: 0;
    in property <int> ram-used-mb: 0;
    in property <int> ram-total-mb: 0;
    
    // COSMIC companion app availability / status
    in property <bool> cosmic-tweaks-available: false;
    in property <bool> fan-control-available: false;
    in property <bool> color-picker-available: false;
    in property <string> cosmic-tweaks-status: "";
    in property <string> fan-control-status: "";
    in property <string> color-picker-status: "";

    // COSMIC themes
    in property <[CosmicThemeData]> cosmic-themes: [];
    in property <bool> themes-loading: false;
    in property <string> themes-error: "";
    in property <int> installing-theme-id: -1;
    
    callback apply-tweaks;
    callback reset-defaults;
    callback set-profile(string);
    callback launch-cosmic-tweaks;
    callback launch-fan-control;
    callback launch-color-picker;
    callback refresh-themes;
    callback install-theme(int);
    
    background: Theme.background;
    
    Flickable {
        viewport-height: content.preferred-height;
        
        content := VerticalLayout {
            padding: Theme.spacing-lg;
            spacing: Theme.spacing-lg;
            
            // Header
            HorizontalLayout {
                Text {
                    text: "System Tweaks";
                    font-size: Theme.font-xxl;
                    font-weight: 700;
                    color: Theme.text-primary;
                }
                Rectangle { horizontal-stretch: 1; }
                TweakButton {
                    label: "Reset All";
                    clicked => { reset-defaults(); }
                }
                TweakButton {
                    label: "Apply All";
                    primary: true;
                    clicked => { apply-tweaks(); }
                }
            }

            // Live resource monitor bar
            ResourceBar {
                cpu-pct: cpu-usage;
                ram-pct: ram-usage-pct;
                ram-used-mb: ram-used-mb;
                ram-total-mb: ram-total-mb;
            }
            
            // Quick Profiles
            Card {
                title: "Quick Profiles";
                
                HorizontalLayout {
                    spacing: Theme.spacing-sm;
                    
                    TweakButton { label: "🔋 Battery Saver"; clicked => { root.set-profile("battery"); } }
                    TweakButton { label: "⚖️ Balanced"; clicked => { root.set-profile("balanced"); } }
                    TweakButton { label: "🚀 Performance"; clicked => { root.set-profile("performance"); } }
                    TweakButton { label: "📺 Presentation"; clicked => { root.set-profile("presentation"); } }
                }
            }
            
            // CPU & Performance
            Card {
                title: "CPU & Performance";
                
                VerticalLayout {
                    spacing: Theme.spacing-md;
                    
                    TweakSelect {
                        label: "CPU Governor";
                        options: ["powersave", "schedutil", "performance"];
                        selected-index <=> cpu-governor-index;
                    }
                    
                    ToggleSwitch {
                        label: "Enable Turbo Boost";
                        checked <=> turbo-enabled;
                    }
                }
            }
            
            // Memory
            Card {
                title: "Memory Management";
                
                VerticalLayout {
                    spacing: Theme.spacing-md;
                    
                    TweakSlider {
                        label: "Swappiness";
                        minimum: 0;
                        maximum: 100;
                        value <=> swappiness;
                        unit: "";
                    }
                    
                    TweakSlider {
                        label: "VFS Cache Pressure";
                        minimum: 0;
                        maximum: 200;
                        value <=> vfs-cache-pressure;
                        unit: "";
                    }
                    
                    ToggleSwitch {
                        label: "Enable ZRAM Compressed Swap";
                        checked <=> zram-enabled;
                    }
                }
            }
            
            // Storage
            Card {
                title: "Storage (NVMe)";
                
                VerticalLayout {
                    spacing: Theme.spacing-md;
                    
                    TweakSelect {
                        label: "I/O Scheduler";
                        options: ["none", "mq-deadline", "kyber"];
                        selected-index <=> io-scheduler-index;
                    }
                    
                    ToggleSwitch {
                        label: "Enable Automatic TRIM (fstrim.timer)";
                        checked <=> trim-enabled;
                    }
                }
            }
            
            // GPU
            Card {
                title: "Intel GPU";
                
                VerticalLayout {
                    spacing: Theme.spacing-md;
                    
                    ToggleSwitch {
                        label: "Enable GuC/HuC Firmware Loading";
                        checked <=> intel-guc-enabled;
                    }
                    
                    ToggleSwitch {
                        label: "Enable Panel Self Refresh (PSR)";
                        checked <=> intel-psr-enabled;
                    }
                    
                    ToggleSwitch {
                        label: "Enable Framebuffer Compression (FBC)";
                        checked <=> intel-fbc-enabled;
                    }
                }
            }
            
            // Power
            Card {
                title: "Power Management";
                
                VerticalLayout {
                    spacing: Theme.spacing-md;
                    
                    ToggleSwitch {
                        label: "WiFi Power Save Mode";
                        checked <=> wifi-powersave;
                    }
                    
                    ToggleSwitch {
                        label: "Audio Power Save";
                        checked <=> audio-powersave;
                    }
                }
            }
            
            // Network
            Card {
                title: "Network Optimization";
                
                VerticalLayout {
                    spacing: Theme.spacing-md;
                    
                    TweakSlider {
                        label: "TCP Fast Open";
                        minimum: 0;
                        maximum: 3;
                        value <=> tcp-fastopen;
                        unit: "";
                    }
                    
                    ToggleSwitch {
                        label: "TCP Low Latency";
                        checked <=> tcp-low-latency;
                    }
                    
                    ToggleSwitch {
                        label: "Enable BBR Congestion Control";
                        checked <=> bbr-enabled;
                    }
                }
            }
            
            // Kernel
            Card {
                title: "Kernel Tweaks";
                
                VerticalLayout {
                    spacing: Theme.spacing-md;
                    
                    ToggleSwitch {
                        label: "Enable System Watchdog";
                        checked <=> watchdog-enabled;
                    }
                    
                    TweakSelect {
                        label: "Transparent Huge Pages";
                        options: ["always", "madvise", "never"];
                        selected-index <=> thp-index;
                    }
                }
            }

            // ── COSMIC Desktop Integration (Themes + Apps combined) ──────────────
            Card {
                title: "🪐 COSMIC Themes & Desktop Apps";

                VerticalLayout {
                    spacing: Theme.spacing-md;

                    // Theme gallery header
                    HorizontalLayout {
                        spacing: Theme.spacing-sm;
                        Text {
                            text: "Browse and install community themes from cosmic-themes.org";
                            color: Theme.text-secondary;
                            font-size: Theme.font-sm;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                            wrap: word-wrap;
                        }
                        TweakButton {
                            label: themes-loading ? "Loading…" : "↻ Refresh";
                            enabled: !themes-loading;
                            clicked => { refresh-themes(); }
                        }
                        TweakButton {
                            label: "🌐 Open Site";
                            clicked => {
                                // opens in default browser via Rust callback
                                refresh-themes();
                            }
                        }
                    }

                    // Error state
                    if themes-error != "" : Rectangle {
                        height: 36px;
                        background: #2a1a1a;
                        border-radius: Theme.radius-md;
                        border-width: 1px;
                        border-color: Theme.error;
                        HorizontalLayout {
                            padding-left: Theme.spacing-md;
                            Text {
                                text: "⚠ " + themes-error;
                                color: Theme.error;
                                font-size: Theme.font-sm;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // Loading state
                    if themes-loading && cosmic-themes.length == 0 : Rectangle {
                        height: 60px;
                        background: Theme.surface-variant;
                        border-radius: Theme.radius-md;
                        HorizontalLayout {
                            alignment: center;
                            Text {
                                text: "⏳ Fetching themes from cosmic-themes.org…";
                                color: Theme.text-muted;
                                font-size: Theme.font-sm;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // Theme gallery grid (two columns)
                    if cosmic-themes.length > 0 : VerticalLayout {
                        spacing: Theme.spacing-xs;

                        for theme in cosmic-themes : CosmicThemeCard {
                            theme-name: theme.name;
                            theme-author: theme.author;
                            theme-downloads: theme.downloads;
                            theme-is-dark: theme.is-dark;
                            accent-col: rgba(theme.accent-r, theme.accent-g, theme.accent-b, 255);
                            bg-col: rgba(theme.bg-r, theme.bg-g, theme.bg-b, 255);
                            installing: installing-theme-id == theme.id;
                            install-clicked => { install-theme(theme.id); }
                        }
                    }

                    // Empty state (no themes loaded yet)
                    if cosmic-themes.length == 0 && !themes-loading : Rectangle {
                        height: 70px;
                        background: Theme.surface-variant;
                        border-radius: Theme.radius-md;
                        HorizontalLayout {
                            alignment: center;
                            VerticalLayout {
                                alignment: center;
                                spacing: 4px;
                                Text {
                                    text: "No themes loaded";
                                    color: Theme.text-muted;
                                    font-size: Theme.font-sm;
                                    horizontal-alignment: center;
                                }
                                Text {
                                    text: "Click ↻ Refresh to fetch from cosmic-themes.org";
                                    color: Theme.text-muted;
                                    font-size: Theme.font-xs;
                                    horizontal-alignment: center;
                                }
                            }
                        }
                    }

                    // Divider
                    Rectangle { height: 1px; background: Theme.border; }

                    // COSMIC companion app launchers (retained below gallery)
                    Text {
                        text: "COSMIC companion apps:";
                        color: Theme.text-secondary;
                        font-size: Theme.font-sm;
                        font-weight: 600;
                    }

                    HorizontalLayout {
                        spacing: Theme.spacing-sm;

                        // cosmic-tweaks
                        Rectangle {
                            horizontal-stretch: 1;
                            height: 72px;
                            background: cosmic-tweaks-available ? Theme.surface-variant : #151515;
                            border-radius: Theme.radius-md;
                            border-width: 1px;
                            border-color: ct-touch.has-hover && cosmic-tweaks-available ? Theme.accent : Theme.border;
                            opacity: cosmic-tweaks-available ? 1.0 : 0.5;
                            animate border-color { duration: 120ms; }

                            ct-touch := TouchArea {
                                mouse-cursor: cosmic-tweaks-available ? pointer : default;
                                clicked => { if (cosmic-tweaks-available) { launch-cosmic-tweaks(); } }
                            }
                            VerticalLayout {
                                padding: Theme.spacing-sm;
                                spacing: 2px;
                                alignment: center;
                                Text { text: "🔧"; font-size: 22px; horizontal-alignment: center; }
                                Text {
                                    text: "COSMIC Tweaks";
                                    color: cosmic-tweaks-available ? Theme.text-primary : Theme.text-muted;
                                    font-size: Theme.font-xs;
                                    font-weight: 600;
                                    horizontal-alignment: center;
                                }
                                Text {
                                    text: cosmic-tweaks-available ? "› Open" : (cosmic-tweaks-status != "" ? cosmic-tweaks-status : "Not installed");
                                    color: cosmic-tweaks-available ? Theme.accent : Theme.text-muted;
                                    font-size: Theme.font-xs;
                                    horizontal-alignment: center;
                                    wrap: word-wrap;
                                }
                            }
                        }

                        // fan-control
                        Rectangle {
                            horizontal-stretch: 1;
                            height: 72px;
                            background: fan-control-available ? Theme.surface-variant : #151515;
                            border-radius: Theme.radius-md;
                            border-width: 1px;
                            border-color: fc-touch.has-hover && fan-control-available ? Theme.accent : Theme.border;
                            opacity: fan-control-available ? 1.0 : 0.5;
                            animate border-color { duration: 120ms; }

                            fc-touch := TouchArea {
                                mouse-cursor: fan-control-available ? pointer : default;
                                clicked => { if (fan-control-available) { launch-fan-control(); } }
                            }
                            VerticalLayout {
                                padding: Theme.spacing-sm;
                                spacing: 2px;
                                alignment: center;
                                Text { text: "🌀"; font-size: 22px; horizontal-alignment: center; }
                                Text {
                                    text: "Fan Control";
                                    color: fan-control-available ? Theme.text-primary : Theme.text-muted;
                                    font-size: Theme.font-xs;
                                    font-weight: 600;
                                    horizontal-alignment: center;
                                }
                                Text {
                                    text: fan-control-available ? "› Open" : (fan-control-status != "" ? fan-control-status : "Not installed");
                                    color: fan-control-available ? Theme.accent : Theme.text-muted;
                                    font-size: Theme.font-xs;
                                    horizontal-alignment: center;
                                    wrap: word-wrap;
                                }
                            }
                        }

                        // cosmic-color-picker
                        Rectangle {
                            horizontal-stretch: 1;
                            height: 72px;
                            background: color-picker-available ? Theme.surface-variant : #151515;
                            border-radius: Theme.radius-md;
                            border-width: 1px;
                            border-color: cp-touch.has-hover && color-picker-available ? Theme.accent : Theme.border;
                            opacity: color-picker-available ? 1.0 : 0.5;
                            animate border-color { duration: 120ms; }

                            cp-touch := TouchArea {
                                mouse-cursor: color-picker-available ? pointer : default;
                                clicked => { if (color-picker-available) { launch-color-picker(); } }
                            }
                            VerticalLayout {
                                padding: Theme.spacing-sm;
                                spacing: 2px;
                                alignment: center;
                                Text { text: "🎨"; font-size: 22px; horizontal-alignment: center; }
                                Text {
                                    text: "Color Picker";
                                    color: color-picker-available ? Theme.text-primary : Theme.text-muted;
                                    font-size: Theme.font-xs;
                                    font-weight: 600;
                                    horizontal-alignment: center;
                                }
                                Text {
                                    text: color-picker-available ? "› Open" : (color-picker-status != "" ? color-picker-status : "Not installed");
                                    color: color-picker-available ? Theme.accent : Theme.text-muted;
                                    font-size: Theme.font-xs;
                                    horizontal-alignment: center;
                                    wrap: word-wrap;
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

// Cleaner Tab Content — wrapped in Flickable so all content is reachable
component CleanerTab inherits Rectangle {
    in property <float> apt-cache-size: 0;
    in property <float> thumbnail-cache-size: 0;
    in property <float> journal-size: 0;
    in property <float> temp-size: 0;
    in property <int> orphan-packages: 0;
    in-out property <bool> apt-cache-selected: true;
    in-out property <bool> thumbnail-selected: true;
    in-out property <bool> journal-selected: false;
    in-out property <bool> temp-selected: true;
    in-out property <bool> orphan-selected: false;
    in property <bool> is-scanning: false;
    in property <bool> is-cleaning: false;
    in property <bool> krokiet-available: false;
    in property <bool> czkawka-cli-available: false;
    in property <string> czkawka-status: "Checking...";
    in property <int> czkawka-result-count: 0;
    in property <bool> is-czkawka-scanning: false;
    callback scan;
    callback clean;
    callback find-duplicates;
    callback launch-czkawka-scan(string);
    callback install-krokiet;
    
    background: Theme.background;
    
    Flickable {
        viewport-height: cleaner-content.preferred-height;

        cleaner-content := VerticalLayout {
            padding: Theme.spacing-lg;
            spacing: Theme.spacing-lg;
            
            // Header
            HorizontalLayout {
                Text {
                    text: "System Cleaner";
                    font-size: Theme.font-xxl;
                    font-weight: 700;
                    color: Theme.text-primary;
                }
                Rectangle { horizontal-stretch: 1; }
                TweakButton {
                    label: is-scanning ? "Scanning..." : "Scan";
                    enabled: !is-scanning && !is-cleaning;
                    clicked => { scan(); }
                }
                TweakButton {
                    label: is-cleaning ? "Cleaning..." : "Clean Selected";
                    primary: true;
                    enabled: !is-scanning && !is-cleaning;
                    clicked => { clean(); }
                }
            }
            
            // Cleanable items
            Card {
                title: "Cache & Temporary Files";
                
                VerticalLayout {
                    spacing: Theme.spacing-sm;
                    
                    HorizontalLayout {
                        spacing: Theme.spacing-md;
                        ToggleSwitch {
                            label: "APT Package Cache";
                            checked <=> apt-cache-selected;
                        }
                        Text {
                            text: apt-cache-size > 0 ? round(apt-cache-size) + " MB" : "—";
                            color: Theme.accent;
                            font-size: Theme.font-sm;
                            vertical-alignment: center;
                        }
                    }
                    
                    HorizontalLayout {
                        spacing: Theme.spacing-md;
                        ToggleSwitch {
                            label: "Thumbnail Cache";
                            checked <=> thumbnail-selected;
                        }
                        Text {
                            text: thumbnail-cache-size > 0 ? round(thumbnail-cache-size) + " MB" : "—";
                            color: Theme.accent;
                            font-size: Theme.font-sm;
                            vertical-alignment: center;
                        }
                    }
                    
                    HorizontalLayout {
                        spacing: Theme.spacing-md;
                        ToggleSwitch {
                            label: "System Journal Logs";
                            checked <=> journal-selected;
                        }
                        Text {
                            text: journal-size > 0 ? round(journal-size) + " MB" : "—";
                            color: Theme.accent;
                            font-size: Theme.font-sm;
                            vertical-alignment: center;
                        }
                    }
                    
                    HorizontalLayout {
                        spacing: Theme.spacing-md;
                        ToggleSwitch {
                            label: "Temporary Files (/tmp, /var/tmp)";
                            checked <=> temp-selected;
                        }
                        Text {
                            text: temp-size > 0 ? round(temp-size) + " MB" : "—";
                            color: Theme.accent;
                            font-size: Theme.font-sm;
                            vertical-alignment: center;
                        }
                    }
                }
            }
            
            Card {
                title: "Orphaned Packages";
                
                VerticalLayout {
                    spacing: Theme.spacing-sm;
                    
                    HorizontalLayout {
                        spacing: Theme.spacing-md;
                        ToggleSwitch {
                            label: "Remove orphaned configuration files";
                            checked <=> orphan-selected;
                        }
                        Text {
                            text: orphan-packages > 0 ? orphan-packages + " packages" : "—";
                            color: Theme.warning;
                            font-size: Theme.font-sm;
                            vertical-alignment: center;
                        }
                    }
                }
            }
            
            Card {
                title: "🔍 File Analysis (powered by czkawka / krokiet)";
                
                VerticalLayout {
                    spacing: Theme.spacing-sm;
                    
                    // Status bar
                    Rectangle {
                        height: 36px;
                        background: krokiet-available ? #1a2e1a : (czkawka-cli-available ? #2e2a1a : #2a1a1a);
                        border-radius: Theme.radius-md;
                        border-width: 1px;
                        border-color: krokiet-available ? #44ff44 : (czkawka-cli-available ? #ffaa00 : #ff4444);
                        
                        HorizontalLayout {
                            padding-left: Theme.spacing-md;
                            padding-right: Theme.spacing-md;
                            spacing: Theme.spacing-sm;
                            
                            Text {
                                text: krokiet-available ? "🟢" : (czkawka-cli-available ? "🟡" : "🔴");
                                font-size: Theme.font-md;
                                vertical-alignment: center;
                            }
                            Text {
                                text: czkawka-status;
                                color: krokiet-available ? #44ff44 : (czkawka-cli-available ? #ffaa00 : #ff8888);
                                font-size: Theme.font-sm;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }
                            if is-czkawka-scanning : Text {
                                text: "⏳ Scanning...";
                                color: Theme.accent;
                                font-size: Theme.font-sm;
                                vertical-alignment: center;
                            }
                            if czkawka-result-count > 0 : Text {
                                text: czkawka-result-count + " groups found";
                                color: Theme.warning;
                                font-size: Theme.font-sm;
                                font-weight: 600;
                                vertical-alignment: center;
                            }
                        }
                    }
                    
                    // Description
                    Text {
                        text: krokiet-available
                            ? "Click any scan mode below to open krokiet — a powerful file analysis tool with a full GUI."
                            : (czkawka-cli-available
                                ? "czkawka_cli is available for headless scans. Install krokiet for the full GUI experience."
                                : "Install krokiet to enable all file analysis features.");
                        color: Theme.text-secondary;
                        font-size: Theme.font-sm;
                        wrap: word-wrap;
                    }
                    
                    // Grid of scan mode buttons
                    HorizontalLayout {
                        spacing: Theme.spacing-sm;
                        
                        // Column 1
                        VerticalLayout {
                            spacing: Theme.spacing-xs;
                            horizontal-stretch: 1;
                            
                            CzkawkaModeButton {
                                icon: "📄";
                                label: "Duplicate Files";
                                description: "Find exact copy files";
                                available: krokiet-available || czkawka-cli-available;
                                scanning: is-czkawka-scanning;
                                clicked => { launch-czkawka-scan("dup"); }
                            }
                            CzkawkaModeButton {
                                icon: "📭";
                                label: "Empty Files";
                                description: "Zero-byte files";
                                available: krokiet-available || czkawka-cli-available;
                                scanning: is-czkawka-scanning;
                                clicked => { launch-czkawka-scan("empty-files"); }
                            }
                            CzkawkaModeButton {
                                icon: "📂";
                                label: "Empty Directories";
                                description: "Unused empty folders";
                                available: krokiet-available || czkawka-cli-available;
                                scanning: is-czkawka-scanning;
                                clicked => { launch-czkawka-scan("empty-dirs"); }
                            }
                            CzkawkaModeButton {
                                icon: "🖼";
                                label: "Similar Images";
                                description: "Visually similar photos";
                                available: krokiet-available || czkawka-cli-available;
                                scanning: is-czkawka-scanning;
                                clicked => { launch-czkawka-scan("similar-images"); }
                            }
                        }
                        
                        // Column 2
                        VerticalLayout {
                            spacing: Theme.spacing-xs;
                            horizontal-stretch: 1;
                            
                            CzkawkaModeButton {
                                icon: "🎬";
                                label: "Similar Videos";
                                description: "Near-duplicate clips";
                                available: krokiet-available || czkawka-cli-available;
                                scanning: is-czkawka-scanning;
                                clicked => { launch-czkawka-scan("similar-videos"); }
                            }
                            CzkawkaModeButton {
                                icon: "🎵";
                                label: "Same Music";
                                description: "Duplicate audio tracks";
                                available: krokiet-available || czkawka-cli-available;
                                scanning: is-czkawka-scanning;
                                clicked => { launch-czkawka-scan("same-music"); }
                            }
                            CzkawkaModeButton {
                                icon: "🔗";
                                label: "Invalid Symlinks";
                                description: "Broken symbolic links";
                                available: krokiet-available || czkawka-cli-available;
                                scanning: is-czkawka-scanning;
                                clicked => { launch-czkawka-scan("symlinks"); }
                            }
                            CzkawkaModeButton {
                                icon: "💔";
                                label: "Broken Files";
                                description: "Corrupted archives/ZIPs";
                                available: krokiet-available || czkawka-cli-available;
                                scanning: is-czkawka-scanning;
                                clicked => { launch-czkawka-scan("broken"); }
                            }
                        }
                        
                        // Column 3
                        VerticalLayout {
                            spacing: Theme.spacing-xs;
                            horizontal-stretch: 1;
                            
                            CzkawkaModeButton {
                                icon: "🏷";
                                label: "Bad Extensions";
                                description: "Wrong file extensions";
                                available: krokiet-available || czkawka-cli-available;
                                scanning: is-czkawka-scanning;
                                clicked => { launch-czkawka-scan("bad-ext"); }
                            }
                            CzkawkaModeButton {
                                icon: "📦";
                                label: "Big Files";
                                description: "Largest files on disk";
                                available: krokiet-available || czkawka-cli-available;
                                scanning: is-czkawka-scanning;
                                clicked => { launch-czkawka-scan("big"); }
                            }
                            CzkawkaModeButton {
                                icon: "🗑";
                                label: "Temporary Files";
                                description: "Junk & temp files";
                                available: krokiet-available || czkawka-cli-available;
                                scanning: is-czkawka-scanning;
                                clicked => { launch-czkawka-scan("temp"); }
                            }
                            
                            // Install button (shown when neither tool is found)
                            if !krokiet-available && !czkawka-cli-available : TweakButton {
                                label: "⬇ Install krokiet";
                                primary: true;
                                enabled: !is-czkawka-scanning;
                                clicked => { install-krokiet(); }
                            }
                        }
                    }
                    
                    // Attribution note
                    Text {
                        text: krokiet-available
                            ? "Powered by krokiet (Czkawka) — MIT license — github.com/qarmin/czkawka"
                            : "krokiet — install via: cargo install krokiet --locked";
                        color: Theme.text-muted;
                        font-size: Theme.font-xs;
                        horizontal-alignment: right;
                    }
                }
            }
        }
    }
}

// Backup Tab Content
component BackupTab inherits Rectangle {
    in property <string> remote-name: "Not configured";
    in property <bool> is-configured: false;
    in property <[string]> queued-files: [];
    in property <float> transfer-progress: 0;
    in property <bool> is-transferring: false;
    callback configure-rclone;
    callback select-files;
    callback start-sync;
    
    background: Theme.background;
    
    Flickable {
        viewport-height: backup-content.preferred-height;

        backup-content := VerticalLayout {
            padding: Theme.spacing-lg;
            spacing: Theme.spacing-lg;
            
            // Header
            Text {
                text: "Backup (Rclone)";
                font-size: Theme.font-xxl;
                font-weight: 700;
                color: Theme.text-primary;
            }
            
            // Remote configuration
            Card {
                title: "Remote Configuration";
                
                VerticalLayout {
                    spacing: Theme.spacing-md;
                    
                    HorizontalLayout {
                        spacing: Theme.spacing-md;
                        
                        Text {
                            text: "Current Remote:";
                            color: Theme.text-secondary;
                            font-size: Theme.font-md;
                            vertical-alignment: center;
                        }
                        Text {
                            text: remote-name;
                            color: is-configured ? Theme.success : Theme.warning;
                            font-size: Theme.font-md;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                    }
                    
                    TweakButton {
                        label: is-configured ? "Change Remote" : "Configure Remote";
                        clicked => { configure-rclone(); }
                    }
                }
            }
            
            // File selection
            Card {
                title: "Files to Backup";
                
                VerticalLayout {
                    spacing: Theme.spacing-sm;
                    
                    if queued-files.length == 0 : Text {
                        text: "No files selected. Click below to open the file picker.";
                        color: Theme.text-muted;
                        font-size: Theme.font-sm;
                    }

                    // Show count when files are selected
                    if queued-files.length > 0 : HorizontalLayout {
                        spacing: Theme.spacing-sm;
                        Text {
                            text: "✓ " + queued-files.length + " item(s) selected:";
                            color: Theme.success;
                            font-size: Theme.font-sm;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                    }

                    // Scrollable list of selected file names
                    if queued-files.length > 0 : Rectangle {
                        height: min(queued-files.length * 24px + 12px, 144px);
                        background: Theme.surface-variant;
                        border-radius: Theme.radius-sm;
                        border-width: 1px;
                        border-color: Theme.border;
                        clip: true;

                        Flickable {
                            viewport-height: files-list.preferred-height;

                            files-list := VerticalLayout {
                                padding: 6px;
                                spacing: 2px;

                                for f in queued-files : Text {
                                    text: "  📄 " + f;
                                    color: Theme.text-secondary;
                                    font-size: Theme.font-xs;
                                    overflow: elide;
                                }
                            }
                        }
                    }
                    
                    TweakButton {
                        label: queued-files.length > 0 ? "Change Selection…" : "Select Files…";
                        enabled: is-configured && !is-transferring;
                        clicked => { select-files(); }
                    }
                }
            }
            
            // Transfer
            if is-configured : Card {
                title: "Transfer";
                
                VerticalLayout {
                    spacing: Theme.spacing-md;
                    
                    if is-transferring : ProgressBar {
                        progress: transfer-progress;
                        label: "Uploading…";
                    }
                    
                    TweakButton {
                        label: is-transferring ? "Syncing..." : "Start Sync";
                        primary: true;
                        enabled: is-configured && queued-files.length > 0 && !is-transferring;
                        clicked => { start-sync(); }
                    }
                }
            }
        }
    }
}

// Benchmark Tab Content
component BenchmarkTab inherits Rectangle {
    in property <float> cpu-single-score: 0;
    in property <float> cpu-multi-score: 0;
    in property <float> memory-score: 0;
    in property <float> disk-seq-score: 0;
    in property <float> disk-rand-score: 0;
    in property <bool> is-running: false;
    in property <string> current-test: "";
    in property <bool> sysbench-installed: false;
    in property <bool> fio-installed: false;
    callback run-all;
    callback run-cpu-single;
    callback run-cpu-multi;
    callback run-memory;
    callback run-disk;
    
    background: Theme.background;
    
    VerticalLayout {
        padding: Theme.spacing-lg;
        spacing: Theme.spacing-lg;
        
        // Header
        HorizontalLayout {
            Text {
                text: "System Benchmarks";
                font-size: Theme.font-xxl;
                font-weight: 700;
                color: Theme.text-primary;
            }
            Rectangle { horizontal-stretch: 1; }
            TweakButton {
                label: is-running ? "Running..." : "Run All Benchmarks";
                primary: true;
                enabled: !is-running && sysbench-installed && fio-installed;
                clicked => { run-all(); }
            }
        }
        
        if is-running : Card {
            ProgressBar {
                progress: 0.5;
                label: "Running: " + current-test;
            }
        }
        
        // Results
        HorizontalLayout {
            spacing: Theme.spacing-lg;
            
            // CPU Benchmarks
            Card {
                title: "CPU";
                horizontal-stretch: 1;
                
                VerticalLayout {
                    spacing: Theme.spacing-md;
                    
                    VerticalLayout {
                        Text {
                            text: "Single-Core";
                            color: Theme.text-secondary;
                            font-size: Theme.font-sm;
                        }
                        Text {
                            text: cpu-single-score > 0 ? round(cpu-single-score) + " events/s" : "—";
                            color: Theme.accent;
                            font-size: Theme.font-lg;
                            font-weight: 600;
                        }
                        TweakButton {
                            label: "Run";
                            enabled: !is-running;
                            clicked => { run-cpu-single(); }
                        }
                    }
                    
                    VerticalLayout {
                        Text {
                            text: "Multi-Core";
                            color: Theme.text-secondary;
                            font-size: Theme.font-sm;
                        }
                        Text {
                            text: cpu-multi-score > 0 ? round(cpu-multi-score) + " events/s" : "—";
                            color: Theme.accent;
                            font-size: Theme.font-lg;
                            font-weight: 600;
                        }
                        TweakButton {
                            label: "Run";
                            enabled: !is-running;
                            clicked => { run-cpu-multi(); }
                        }
                    }
                }
            }
            
            // Memory Benchmark
            Card {
                title: "Memory";
                horizontal-stretch: 1;
                
                VerticalLayout {
                    spacing: Theme.spacing-md;
                    
                    Text {
                        text: "Bandwidth";
                        color: Theme.text-secondary;
                        font-size: Theme.font-sm;
                    }
                    Text {
                        text: memory-score > 0 ? round(memory-score) + " MB/s" : "—";
                        color: Theme.accent;
                        font-size: Theme.font-lg;
                        font-weight: 600;
                    }
                    TweakButton {
                        label: "Run";
                        enabled: !is-running;
                        clicked => { run-memory(); }
                    }
                }
            }
            
            // Disk Benchmark
            Card {
                title: "Disk (NVMe)";
                horizontal-stretch: 1;
                
                VerticalLayout {
                    spacing: Theme.spacing-md;
                    
                    VerticalLayout {
                        Text {
                            text: "Sequential Read";
                            color: Theme.text-secondary;
                            font-size: Theme.font-sm;
                        }
                        Text {
                            text: disk-seq-score > 0 ? round(disk-seq-score) + " MB/s" : "—";
                            color: Theme.accent;
                            font-size: Theme.font-lg;
                            font-weight: 600;
                        }
                    }
                    
                    VerticalLayout {
                        Text {
                            text: "Random Read";
                            color: Theme.text-secondary;
                            font-size: Theme.font-sm;
                        }
                        Text {
                            text: disk-rand-score > 0 ? round(disk-rand-score) + " IOPS" : "—";
                            color: Theme.accent;
                            font-size: Theme.font-lg;
                            font-weight: 600;
                        }
                    }
                    
                    TweakButton {
                        label: "Run";
                        enabled: !is-running;
                        clicked => { run-disk(); }
                    }
                }
            }
        }
        
        Rectangle { vertical-stretch: 1; }
    }
}

// Main Application Window
export component MainWindow inherits Window {
    title: "Tweakers";
    icon: @image-url("");
    min-width: 1200px;
    min-height: 800px;
    background: Theme.background;
    
    in-out property <int> active-tab: 0;
    in-out property <bool> show-sudo-dialog: false;
    in-out property <string> sudo-password: "";
    in-out property <bool> sudo-loading: false;
    in-out property <string> sudo-error: "";
    in-out property <string> sudo-action: "";
    
    // Tweaks tab properties
    in-out property <int> cpu-governor-index: 1;
    in-out property <bool> turbo-enabled: true;
    in-out property <float> swappiness: 60;
    in-out property <float> vfs-cache-pressure: 100;
    in-out property <bool> zram-enabled: false;
    in-out property <int> io-scheduler-index: 1;
    in-out property <bool> trim-enabled: true;
    in-out property <bool> intel-guc-enabled: false;
    in-out property <bool> intel-psr-enabled: false;
    in-out property <bool> intel-fbc-enabled: false;
    in-out property <bool> wifi-powersave: false;
    in-out property <bool> audio-powersave: false;
    
    // Network
    in-out property <float> tcp-fastopen: 3;
    in-out property <bool> tcp-low-latency: false;
    in-out property <bool> bbr-enabled: false;
    
    // Kernel
    in-out property <bool> watchdog-enabled: true;
    in-out property <int> thp-index: 1;

    // Resource monitor
    in-out property <float> cpu-usage: 0;
    in-out property <float> ram-usage-pct: 0;
    in-out property <int> ram-used-mb: 0;
    in-out property <int> ram-total-mb: 0;
    
    // Cleaner tab properties
    in-out property <float> apt-cache-size: 0;
    in-out property <float> thumbnail-cache-size: 0;
    in-out property <float> journal-size: 0;
    in-out property <float> temp-size: 0;
    in-out property <int> orphan-packages: 0;
    in-out property <bool> is-scanning: false;
    in-out property <bool> is-cleaning: false;
    
    // Cleaner selection
    in-out property <bool> apt-cache-selected: true;
    in-out property <bool> thumbnail-selected: true;
    in-out property <bool> journal-selected: false;
    in-out property <bool> temp-selected: true;
    in-out property <bool> orphan-selected: false;
    
    // Backup tab properties
    in-out property <string> remote-name: "Not configured";
    in-out property <bool> is-configured: false;
    in-out property <[string]> queued-file-names: [];
    in-out property <float> transfer-progress: 0;
    in-out property <bool> is-transferring: false;
    
    // Benchmark tab properties
    in-out property <float> cpu-single-score: 0;
    in-out property <float> cpu-multi-score: 0;
    in-out property <float> memory-score: 0;
    in-out property <float> disk-seq-score: 0;
    in-out property <float> disk-rand-score: 0;
    in-out property <bool> is-running: false;
    in-out property <string> current-test: "";
    in-out property <bool> sysbench-installed: false;
    in-out property <bool> fio-installed: false;
    
    // COSMIC themes
    in-out property <[CosmicThemeData]> cosmic-themes: [];
    in-out property <bool> themes-loading: false;
    in-out property <string> themes-error: "";
    in-out property <int> installing-theme-id: -1;

    // Toast notification
    in-out property <bool> show-toast: false;
    in-out property <string> toast-message: "";
    in-out property <bool> toast-success: true;
    
    // Callbacks to Rust backend
    callback apply-tweaks;
    callback reset-defaults;
    callback scan-cleaner;
    callback clean-selected;
    callback find-duplicates;
    callback configure-rclone;
    callback select-backup-files;
    callback start-backup;
    callback run-benchmark(string);
    callback set-profile(string);
    callback sudo-authenticate(string);
    callback sudo-cancel;
    callback launch-czkawka-scan(string);
    callback install-krokiet;
    callback launch-cosmic-tweaks;
    callback launch-fan-control;
    callback launch-color-picker;
    callback refresh-themes;
    callback install-theme(int);
    
    // czkawka / krokiet state
    in-out property <bool> krokiet-available: false;
    in-out property <bool> czkawka-cli-available: false;
    in-out property <string> czkawka-status: "Checking...";
    in-out property <int> czkawka-result-count: 0;
    in-out property <bool> is-czkawka-scanning: false;

    // COSMIC companion app state
    in-out property <bool> cosmic-tweaks-available: false;
    in-out property <bool> fan-control-available: false;
    in-out property <bool> color-picker-available: false;
    in-out property <string> cosmic-tweaks-status: "";
    in-out property <string> fan-control-status: "";
    in-out property <string> color-picker-status: "";
    
    HorizontalLayout {
        // Sidebar
        Rectangle {
            width: 220px;
            background: Theme.surface;
            
            VerticalLayout {
                padding: Theme.spacing-md;
                spacing: Theme.spacing-sm;
                
                // Logo/Title
                HorizontalLayout {
                    padding: Theme.spacing-md;
                    spacing: Theme.spacing-sm;
                    
                    Text {
                        text: "⚡";
                        font-size: Theme.font-xxl;
                    }
                    Text {
                        text: "Tweakers";
                        font-size: Theme.font-xl;
                        font-weight: 700;
                        color: Theme.primary;
                        vertical-alignment: center;
                    }
                }
                
                Rectangle { height: Theme.spacing-lg; }
                
                NavItem {
                    icon: "🔧";
                    label: "Tweaks";
                    active: active-tab == 0;
                    clicked => { active-tab = 0; }
                }
                
                NavItem {
                    icon: "🧹";
                    label: "Cleaner";
                    active: active-tab == 1;
                    clicked => { active-tab = 1; }
                }
                
                NavItem {
                    icon: "☁️";
                    label: "Backup";
                    active: active-tab == 2;
                    clicked => { active-tab = 2; }
                }
                
                NavItem {
                    icon: "📊";
                    label: "Benchmark";
                    active: active-tab == 3;
                    clicked => { active-tab = 3; }
                }
                
                Rectangle { vertical-stretch: 1; }
                
                // Version info
                Text {
                    text: "v0.1.0";
                    color: Theme.text-muted;
                    font-size: Theme.font-xs;
                    horizontal-alignment: center;
                }
            }
        }
        
        // Main content area
        Rectangle {
            horizontal-stretch: 1;
            
            if active-tab == 0 : TweaksTab {
                cpu-governor-index <=> cpu-governor-index;
                turbo-enabled <=> turbo-enabled;
                swappiness <=> swappiness;
                vfs-cache-pressure <=> vfs-cache-pressure;
                zram-enabled <=> zram-enabled;
                io-scheduler-index <=> io-scheduler-index;
                trim-enabled <=> trim-enabled;
                intel-guc-enabled <=> intel-guc-enabled;
                intel-psr-enabled <=> intel-psr-enabled;
                intel-fbc-enabled <=> intel-fbc-enabled;
                wifi-powersave <=> wifi-powersave;
                audio-powersave <=> audio-powersave;
                tcp-fastopen <=> tcp-fastopen;
                tcp-low-latency <=> tcp-low-latency;
                bbr-enabled <=> bbr-enabled;
                watchdog-enabled <=> watchdog-enabled;
                thp-index <=> thp-index;

                // Resource monitor pass-through
                cpu-usage: cpu-usage;
                ram-usage-pct: ram-usage-pct;
                ram-used-mb: ram-used-mb;
                ram-total-mb: ram-total-mb;

                // COSMIC apps pass-through
                cosmic-tweaks-available: cosmic-tweaks-available;
                fan-control-available: fan-control-available;
                color-picker-available: color-picker-available;
                cosmic-tweaks-status: cosmic-tweaks-status;
                fan-control-status: fan-control-status;
                color-picker-status: color-picker-status;

                // COSMIC themes pass-through
                cosmic-themes: cosmic-themes;
                themes-loading: themes-loading;
                themes-error: themes-error;
                installing-theme-id: installing-theme-id;
                
                apply-tweaks => { apply-tweaks(); }
                reset-defaults => { reset-defaults(); }
                set-profile(p) => { set-profile(p); }
                launch-cosmic-tweaks => { launch-cosmic-tweaks(); }
                launch-fan-control => { launch-fan-control(); }
                launch-color-picker => { launch-color-picker(); }
                refresh-themes => { refresh-themes(); }
                install-theme(id) => { install-theme(id); }
            }
            
            if active-tab == 1 : CleanerTab {
                apt-cache-size: apt-cache-size;
                thumbnail-cache-size: thumbnail-cache-size;
                journal-size: journal-size;
                temp-size: temp-size;
                orphan-packages: orphan-packages;
                is-scanning: is-scanning;
                is-cleaning: is-cleaning;
                
                // czkawka pass-through
                krokiet-available: krokiet-available;
                czkawka-cli-available: czkawka-cli-available;
                czkawka-status: czkawka-status;
                czkawka-result-count: czkawka-result-count;
                is-czkawka-scanning: is-czkawka-scanning;
                
                apt-cache-selected <=> apt-cache-selected;
                thumbnail-selected <=> thumbnail-selected;
                journal-selected <=> journal-selected;
                temp-selected <=> temp-selected;
                orphan-selected <=> orphan-selected;
                
                scan => { scan-cleaner(); }
                clean => { clean-selected(); }
                find-duplicates => { find-duplicates(); }
                launch-czkawka-scan(mode) => { launch-czkawka-scan(mode); }
                install-krokiet => { install-krokiet(); }
            }
            
            if active-tab == 2 : BackupTab {
                remote-name: remote-name;
                is-configured: is-configured;
                queued-files: queued-file-names;
                transfer-progress: transfer-progress;
                is-transferring: is-transferring;
                
                configure-rclone => { configure-rclone(); }
                select-files => { select-backup-files(); }
                start-sync => { start-backup(); }
            }
            
            if active-tab == 3 : BenchmarkTab {
                cpu-single-score: cpu-single-score;
                cpu-multi-score: cpu-multi-score;
                memory-score: memory-score;
                disk-seq-score: disk-seq-score;
                disk-rand-score: disk-rand-score;
                is-running: is-running;
                current-test: current-test;
                sysbench-installed: sysbench-installed;
                fio-installed: fio-installed;
                
                run-all => { run-benchmark("all"); }
                run-cpu-single => { run-benchmark("cpu-single"); }
                run-cpu-multi => { run-benchmark("cpu-multi"); }
                run-memory => { run-benchmark("memory"); }
                run-disk => { run-benchmark("disk"); }
            }
        }
    }
    
    // Sudo dialog overlay
    if show-sudo-dialog : SudoDialog {
        dialog-visible: true;
        action-description: sudo-action;
        password <=> sudo-password;
        is-loading: sudo-loading;
        error-message: sudo-error;
        submit(pwd) => {
            sudo-authenticate(pwd);
        }
        cancel => {
            show-sudo-dialog = false;
            sudo-password = "";
            sudo-error = "";
            sudo-cancel();
        }
    }

    // Toast notification — positioned bottom-right corner
    ToastNotification {
        x: parent.width - self.width - 20px;
        y: parent.height - self.height - 20px;
        toast-visible: show-toast;
        message: toast-message;
        is-success: toast-success;
    }
}
